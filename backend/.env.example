# AutoPoster Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image API (free - get key at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# Google Gemini API (free - get key at https://aistudio.google.com/apikey)
# Used by the Lightroom export plugin for AI blog generation from photos
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# BUSINESS CONFIGURATIONS
# Each business gets its own prefixed block.
# Add as many businesses as you need.
# ─────────────────────────────────────────────

# Business 1: Journey To
BUSINESS_1_ID=journey-to
BUSINESS_1_NAME=Journey To
BUSINESS_1_WP_URL=https://www.letsjourneyto.com
BUSINESS_1_WP_USERNAME=your_wp_username
BUSINESS_1_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Business 2: Tweller Studios
BUSINESS_2_ID=tweller-studios
BUSINESS_2_NAME=Tweller Studios
BUSINESS_2_WP_URL=https://www.twellerstudios.com
BUSINESS_2_WP_USERNAME=your_wp_username
BUSINESS_2_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Add more businesses following the same pattern:
# BUSINESS_3_ID=...
# BUSINESS_3_NAME=...
# BUSINESS_3_WP_URL=...
# BUSINESS_3_WP_USERNAME=...
# BUSINESS_3_WP_APP_PASSWORD=...
