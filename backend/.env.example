# AutoPoster Environment Configuration
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image API (free - get key at https://www.pexels.com/api/)
PEXELS_API_KEY=your_pexels_api_key_here

# ─────────────────────────────────────────────
# BUSINESS CONFIGURATIONS
# Each business gets its own prefixed block.
# Add as many businesses as you need.
# ─────────────────────────────────────────────

# Business 1: Journey To
BUSINESS_1_ID=journey-to
BUSINESS_1_NAME=Journey To
BUSINESS_1_WP_URL=https://www.letsjourneyto.com
BUSINESS_1_WP_USERNAME=your_wp_username
BUSINESS_1_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Business 2: Tweller Studios
BUSINESS_2_ID=tweller-studios
BUSINESS_2_NAME=Tweller Studios
BUSINESS_2_WP_URL=https://www.twellerstudios.com
BUSINESS_2_WP_USERNAME=your_wp_username
BUSINESS_2_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Add more businesses following the same pattern:
# BUSINESS_3_ID=...
# BUSINESS_3_NAME=...
# BUSINESS_3_WP_URL=...
# BUSINESS_3_WP_USERNAME=...
# BUSINESS_3_WP_APP_PASSWORD=...

# ─────────────────────────────────────────────
# PHOTO AUTOMATION PIPELINE
# ─────────────────────────────────────────────

# Folder watcher — root directory containing session photo folders
# Structure: {PHOTO_WATCH_DIR}/{SESSION_CODE}/raw/
PHOTO_WATCH_DIR=/path/to/session-photos

# WordPress callback URL (your WP site URL)
WP_AUTOMATION_URL=https://www.twellerstudios.com
WP_AUTOMATION_API_KEY=your_shared_secret_here

# Imagen AI — AI photo editing (https://www.imagen-ai.com/)
# Leave blank to use built-in auto-edit fallback
IMAGEN_AI_API_KEY=
IMAGEN_AI_PROFILE_ID=
# IMAGEN_AI_BASE_URL=https://api.imagen-ai.com/v1

# Gallery delivery
GALLERY_BASE_URL=https://gallery.twellerstudios.com

# Culling settings
CULL_KEEP_PERCENT=40
CULL_DUPLICATE_THRESHOLD=10
CULL_MIN_SHARPNESS=50

# Edit settings
EDIT_OUTPUT_FORMAT=jpeg
EDIT_OUTPUT_QUALITY=92

# Set to "true" to skip manual edit review (fully automated end-to-end)
AUTO_SKIP_REVIEW=false
